## .NET / Visual Studio gitignore for keon-sdk-csharp

# Build outputs
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
[Oo]ut/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# Test results
[Tt]est[Rr]esult*/
TestResult.xml
*.trx
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# Build logs
*.binlog
MSBuild_Logs/
BenchmarkDotNet.Artifacts/

# Other
*.tmp
*.tmp_proj
.history/
